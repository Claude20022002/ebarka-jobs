# ════════════════════════════════════════════════════════════
#  EBARKA-JOBS — Variables d'environnement
#  Copier ce fichier en .env et remplir les valeurs
# ════════════════════════════════════════════════════════════

# ── DOCKER / PostgreSQL (local) ──────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=ebarka_password
POSTGRES_DB=ebarka_jobs
POSTGRES_PORT=5432

# pgAdmin (interface graphique BDD)
PGADMIN_EMAIL=admin@ebarka.com
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050

# ── BASE DE DONNÉES — Prisma ──────────────────────────────────
# Local Docker :
DATABASE_URL="postgresql://postgres:ebarka_password@localhost:5432/ebarka_jobs?schema=public"
DIRECT_URL="postgresql://postgres:ebarka_password@localhost:5432/ebarka_jobs?schema=public"

# Production Supabase (décommenter) :
# DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true&schema=public"
# DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres?schema=public"

# ── APPLICATION ───────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── AUTH — NextAuth.js v5 ─────────────────────────────────────
# Générer avec : openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here-min-32-chars
AUTH_SECRET=your-secret-here-min-32-chars
NEXTAUTH_URL=http://localhost:3000

# Google OAuth (console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── INTELLIGENCE ARTIFICIELLE — Claude (Anthropic) ───────────
ANTHROPIC_API_KEY=your-anthropic-api-key

# ── UPLOAD FICHIERS — Cloudinary ──────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# ── EMAIL — Resend ────────────────────────────────────────────
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM=noreply@ebarka-jobs.com

# ── RATE LIMITING — Upstash Redis ────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── MONITORING — Sentry ───────────────────────────────────────
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=

# ── PAIEMENTS — Stripe (Phase 2) ─────────────────────────────
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key

# ── LEGACY — Airtable (à supprimer après migration) ──────────
# AIRTABLE_ACCESS_TOKEN=
# AIRTABLE_BASE_ID=
# AIRTABLE_TABLE_NAME=Jobs
